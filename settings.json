{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-context.sh\"",
            "timeout": 5000,
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-dangerous-commands.sh\"",
            "timeout": 5000,
            "statusMessage": "Checking command safety..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-sensitive-edits.sh\"",
            "timeout": 5000,
            "statusMessage": "Checking file protections..."
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/scan-secrets.sh\"",
            "timeout": 5000,
            "statusMessage": "Scanning for secrets..."
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/block-generated-files.sh\"",
            "timeout": 5000,
            "statusMessage": "Checking for build artifacts..."
          }
        ]
      }
    ]
  }
}
